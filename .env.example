# TABOR — environment variables.
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# Items marked (later) are not needed for first dev runs.

# ── Supabase (backend / DB / auth) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ── Anthropic (the System AI) — server-side only, never client ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Printful (international commerce) ──
PRINTFUL_API_KEY=

# ── Checkout (choose one path) ──
# Stripe Checkout:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── South African PoD (African orders) — (later) ──
SAPOD_API_KEY=

# ── Bible content (Scripture pillar) — (later) ──
BIBLE_API_KEY=

# ── Analytics — (later) ──
POSTHOG_KEY=
